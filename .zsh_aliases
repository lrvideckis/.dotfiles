# aliases, inspired by DT: https://gitlab.com/dwt1/dotfiles/-/blob/master/.zshrc

# neovim!!
alias vim='nvim'

# color for grep
alias grep='grep --color=auto'

# confirm before overwriting something
alias rm='rm --interactive'
alias mv='mv --interactive'
alias cp='cp --interactive'
alias mkdir='mkdir --parents'

# improved version of cat: colorized output
alias cat='bat --map-syntax .zsh_aliases:"Bourne Again Shell (bash)"'

# enable support for git bare repo of dotfiles
alias config="/usr/bin/git --git-dir=$HOME/.dotfiles --work-tree=$HOME"

# better du flags - only works on arch :(
dus() {
	du $1 -hd1 | sort -h
}

# changing "ls" to the modern "exa"
alias ls='exa -Fal --color=always --group-directories-first --sort=modified --git' # prefered listing
alias la='exa -a --across --color=always --group-directories-first'  # all files and dirs
alias tree='exa -alT --color=always' # tree listing

# copy contents of file to clipboard - only works on arch :(
clip() {
	cat $1 | xclip -sel clip
}

alias pacsyu='sudo pacman -Syu' # update only standard pkgs

# misc. (frequently used) programs -> so I don't have to memorize these
alias tldr='tldr' # alternative to man
alias files='pcmanfm'
alias spotify='spotify'
alias firefox='firefox'
alias wally='wally' #zsa keyboard flashing tool
alias minecraft='LC_ALL=C ./.minecraft/launcher/minecraft-launcher' # launch minecraft
alias bluetooth='blueman-manager'
alias volume='alsamixer'
alias photo_editor='gimp'
alias android='android-studio'
alias battery='acpi'
